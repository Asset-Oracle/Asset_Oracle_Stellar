{
  "name": "assetoracle-hedera",
  "version": "1.0.0",
  "description": "Real-world asset tokenization on Hedera",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "ai-service"
  ],
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && bun install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:ai": "cd ai-service && python api.py",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && bun run build"
  },
  "keywords": [
    "hedera",
    "tokenization",
    "real-world-assets",
    "defi",
    "hts",
    "blockchain"
  ],
  "author": "Asset-Oracle Team",
  "license": "MIT"
}